{
  "name": "srt-cli",
  "description": "Simple CLI tool to generate .srt files",
  "version": "0.4.0",
  "author": {
    "name": "Gian Luca Pecile",
    "url": "https://glpecile.xyz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glpecile/text-to-sub.git"
  },
  "bugs": {
    "url": "https://github.com/glpecile/text-to-sub/issues"
  },
  "main": "./src/index.ts",
  "type": "module",
  "bin": {
    "srt-cli": "src/cli.ts"
  },
  "keywords": [
    "srt",
    "subtitles",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.30"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-plugin-dts": "^0.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "scripts": {
    "start": "bun run ./src/index.ts",
    "test": "bun test",
    "lint": "tsc",
    "ci": "bun run lint && bun test",
    "prepublishOnly": "bun run ci",
    "release": "npm publish"
  },
  "dependencies": {
    "boxen": "8.0.1",
    "chalk": "5.6.2",
    "ora": "9.4.1"
  }
